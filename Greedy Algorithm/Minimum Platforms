class Solution {
  public:
    int minPlatform(vector<int>& arr, vector<int>& dep) {
        // code here
        sort(arr.begin(),arr.end());
        sort(dep.begin(),dep.end());
        int i=0,j=0,cnt=0,maxpla=0, n= arr.size();
        while(i<n){
            if(arr[i]<= dep[j]){
                cnt++;
                i++;
            }else{
                cnt--;
                j++;
            }
            maxpla = max(maxpla,cnt);
        }
        return maxpla;
    }
};
